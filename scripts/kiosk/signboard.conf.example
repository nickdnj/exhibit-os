# SignBoard per-device config.
# Edit this file on the SD card at /boot/firmware/signboard.conf before first boot,
# or SSH into the Pi and edit /boot/firmware/signboard.conf then reboot.

# Hostname (shows up as mDNS name, e.g. signboard-pool.local)
HOSTNAME=signboard-pool

# Full URL the kiosk browser will load on boot
KIOSK_URL=https://signboard.vistter.com/display/pool

# Health-check endpoint — kiosk waits for HTTP 200 here before launching chromium
HEALTH_URL=https://signboard.vistter.com/api/health

# Timezone (tzdata format)
TIMEZONE=America/New_York

# Keymap
KEYMAP=us

# Comitup AP hotspot name pattern (used when no WiFi configured)
# "<n>" is replaced with a 4-digit suffix derived from the Pi's MAC
COMITUP_AP_NAME='signboard-setup-<n>'
