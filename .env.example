# SignBoard Environment Configuration
# Copy to .env and fill in values

# Security
JWT_SECRET_KEY=change-me-to-a-random-string
DEFAULT_ADMIN_PASSWORD=change-me

# Database
DATABASE_URL=sqlite:///data/signboard.db

# Tempest Weather
TEMPEST_API_TOKEN=your-tempest-api-token
TEMPEST_STATION_ID=183092

# NOAA Tides
NOAA_STATION_ID=8531680

# TagSmart (Phase 3)
TAGSMART_API_URL=http://host.docker.internal:8080
TAGSMART_API_KEY=

# Display
TIMEZONE=America/New_York

# Server
LOG_FORMAT=json
LOG_LEVEL=INFO
CORS_ORIGIN=http://192.168.12.136:8100
UPLOADS_DIR=/data/uploads
